# Meta Pixel Conversions API (server-side PageView events)
META_PIXEL_ID=
META_ACCESS_TOKEN=
# Required for server-side CAPI calls (appsecret_proof)
META_APP_SECRET=
# Optional: override the default v18.0
# META_CAPI_VERSION=v18.0

# Matomo Tracking API
MATOMO_URL=https://platform.iabai.net/
MATOMO_SITE_ID=1
# Required for IP override and real-time reporting
MATOMO_TOKEN_AUTH=
# Comma-separated IPs to skip in Matomo (e.g. your office IP)
MATOMO_EXCLUDE_IPS=
